# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# GitHub personal access token — needs "repo" scope
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Comma-separated list of repos to watch (owner/repo format)
GITHUB_REPOS=owner/repo1,owner/repo2

# Discord webhook URL — create one in Discord channel settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# Polling interval in seconds (default: 300 = 5 minutes)
POLL_INTERVAL=300
